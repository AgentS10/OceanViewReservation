@startuml OceanViewReservation_SequenceDiagram_CreateReservation
' =========================================================
' CIS6003 Advanced Programming — WRIT1 Assignment 2025/26
' Author: Mohamed Subair Mohamed Sajidh
' Sequence Diagram — Create Reservation Flow
' =========================================================

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam shadowing false

actor       "Logged-in User\n(Browser)"       as USER
participant "add-reservation.html"             as HTML
participant "api.js\nReservationAPI"           as API
participant "ReservationHandler\n(Backend)"    as RH    #LightBlue
participant "BaseHandler\nauthenticate()"      as BASE  #LightGray
participant "SessionManager"                   as SM    #LightCoral
participant "RoomTypeDAO"                      as RTDAO #LightGreen
participant "ValidationUtil"                   as VAL   #LightYellow
participant "ReservationDAO"                   as RDAO  #LightGreen
participant "ReservationNotifier\n(Observer)"  as NOTIF #Wheat
participant "LogNotificationObserver"          as LOG   #Wheat
database    "MySQL\noceanview_db"              as DB

USER  -> HTML  : Fill form (guest name, room type,\ncheck-in, check-out, ...)
HTML  -> HTML  : Client-side validation
HTML  -> API   : ReservationAPI.create(data)
API   -> RH    : POST /api/reservations\nAuthorization: Bearer <token>

RH    -> BASE  : authenticate(exchange)
BASE  -> SM    : getUser(token)
SM   --> BASE  : User (or null)
BASE --> RH    : authenticated User

alt Not authenticated
    RH --> API : 401 { success: false, message: "Authentication required" }
    API --> HTML : Show error
    HTML --> USER : Alert: Please log in
else Authenticated
    RH    -> VAL   : validate guestName, contactNumber, dates
    VAL  --> RH    : valid / error message

    alt Validation fails
        RH --> API : 400 { success: false, message: "..." }
        API --> HTML : Show validation error
        HTML --> USER : Inline error message
    else Validation passes
        RH    -> RTDAO : findByName(roomTypeName)
        RTDAO -> DB    : SELECT * FROM room_types WHERE type_name = ?
        DB   --> RTDAO : RoomType row
        RTDAO --> RH   : RoomType object

        RH    -> RH    : Generate reservation number\n(RES-YYYYMMDD-XXXX)
        RH    -> RDAO  : create(reservation)
        RDAO  -> DB    : INSERT INTO reservations (...)
        DB   --> RDAO  : Success / error
        RDAO --> RH    : true

        RH    -> NOTIF : notifyCreated(reservation)
        NOTIF -> LOG   : onReservationCreated(reservation)
        LOG  --> NOTIF : Log to console

        RH --> API  : 201 { success: true,\n        reservationNumber: "RES-...",\n        reservation: {...} }
        API --> HTML : Display success alert
        HTML --> USER : "Reservation created: RES-..."
    end
end

@enduml
